{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Api": {
    "BaseUrl": "http://localhost:5200"
  },
  // Browser SSO (public identifiers only — provider verification and secrets live at the API).
  // Empty values disable that provider's button; deployment supplies real ones via env vars.
  "Auth": {
    "Google": { "ClientId": "" },
    "Apple": { "ServicesId": "" }
  },
  // Public Turnstile widget site key; empty = widget not rendered.
  "Turnstile": { "SiteKey": "" },
  // Config-backed flags until the flags SDK is wired (ROADMAP Phase 0 leftover). Unknown/absent
  // flags read as off, so sign-in stays dark unless a deployment turns it on.
  "Flags": {
    "web.sign_in_enabled": false,
    "web.apply_from_browser": false,
    "web.manage_enabled": false,
    "web.availability_picker": false
  },
  "Brand": {
    "Name": "Steeple",
    "Tagline": "Community space, near you",
    "FooterTagline": "A neighbourly noticeboard for spare community halls."
  },
  // Mobile deep links (CONTRACTS §9): Universal Links (iOS) / App Links (Android) well-known
  // files. Empty = both /.well-known endpoints 404 (no app registered yet); deployment supplies
  // real values once the mobile app ships.
  "DeepLinks": {
    "AppleAppId": "",
    "AndroidPackage": "",
    "AndroidSha256Fingerprints": []
  }
}
