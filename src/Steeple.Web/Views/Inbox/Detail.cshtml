@model ApplicationThreadViewModel
@{
    var app = Model.Application;
    var spaceUrl = Url.Content($"~/space/{app.VenueSlug}/{app.RoomSlug}");
    var backUrl = Model.ViewerIsOrganizer ? Url.Content("~/inbox") : Url.Content("~/manage/applications");
    var replyUrl = Model.ViewerIsOrganizer
        ? Url.Content($"~/inbox/applications/{app.Id}/reply")
        : Url.Content($"~/manage/applications/{app.Id}/reply");
}

<section class="thread-page wrap">
    <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="@backUrl">← All requests</a>
    </nav>

    @if (Model.Flash is not null)
    {
        <p class="thread-flash" role="status">@Model.Flash</p>
    }
    @if (Model.Error is not null)
    {
        <p class="auth-error" role="alert">@Model.Error</p>
    }

    <header class="thread-head">
        <div class="thread-head-main">
            <h1 class="thread-title">
                @if (Model.ViewerIsOrganizer)
                {
                    <a href="@spaceUrl">@app.RoomName</a>
                }
                else
                {
                    @app.Organizer.DisplayName
                }
            </h1>
            <p class="thread-sub">
                @if (Model.ViewerIsOrganizer)
                {
                    <text>@app.VenueName</text>
                }
                else
                {
                    <text>asking for <a href="@spaceUrl">@app.RoomName</a></text>
                }
            </p>
        </div>
        <partial name="_StatusChip" model="app.Status" />
    </header>

    <div class="thread-grid">
        <div class="thread-main">
            @if (Model.ViewerIsOrganizer && Model.OrganizerHasOpenCounter && app.CounterOffer is { } offer)
            {
                @* Counter-offer card (CONTRACTS §5, §8.4 info pair): requested-vs-offered diff + accept/decline.
                   Accept is behind a <details> confirm (CSP: no JS confirm dialogs). *@
                <section class="counter-card" aria-labelledby="counter-card-title">
                    <p class="counter-card-eyebrow" id="counter-card-title">@app.VenueName suggested a different time</p>
                    <dl class="counter-diff">
                        <div class="counter-line counter-line-was">
                            <dt>You asked for</dt>
                            <dd>@ApplicationDisplay.DescribeSchedule(app.Schedule)</dd>
                        </div>
                        <div class="counter-line counter-line-offered">
                            <dt>They suggest</dt>
                            <dd>@ApplicationDisplay.DescribeSchedule(offer.Schedule)</dd>
                        </div>
                    </dl>
                    @if (!string.IsNullOrWhiteSpace(offer.Message))
                    {
                        <blockquote class="counter-message">@offer.Message</blockquote>
                    }
                    <div class="counter-card-actions">
                        <details class="account-confirm counter-accept">
                            <summary class="btn btn-primary">Accept this time</summary>
                            <p class="decision-note">
                                This books @ApplicationDisplay.DescribeSchedule(offer.Schedule) — your original ask goes away.
                            </p>
                            <form method="post" action="@Url.Content($"~/inbox/applications/{app.Id}/counter-offer/respond")">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-primary" name="decision" value="accept">Confirm this time</button>
                            </form>
                        </details>
                        <form method="post" action="@Url.Content($"~/inbox/applications/{app.Id}/counter-offer/respond")">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-ghost" name="decision" value="decline">Decline</button>
                        </form>
                    </div>
                </section>
            }
            else if (Model.ViewerIsOrganizer && Model.CounterOffersEnabled
                     && app.CounterOffer is { Status: "declinedByOrganizer" or "lapsed" or "superseded" } past)
            {
                <p class="thread-note" role="note">
                    @(past.Status switch
                    {
                        "declinedByOrganizer" => "You declined the suggested time.",
                        "lapsed" => "The suggested time lapsed.",
                        _ => "A newer time was suggested.",
                    })
                </p>
            }

            <div class="request-card">
                <p class="request-card-heading">The request</p>
                <dl class="request-facts">
                    <div>
                        <dt>Activity</dt>
                        <dd>@DiscoveryViewModel.Humanize(app.ActivityType) · @app.GroupSize people</dd>
                    </div>
                    <div>
                        <dt>When</dt>
                        <dd>@ApplicationDisplay.DescribeSchedule(app.Schedule)</dd>
                    </div>
                </dl>
                <blockquote class="request-intent">@app.IntentText</blockquote>
                <p class="request-meta">
                    Asked @ApplicationDisplay.RelativeTime(app.CreatedAtUtc)
                    @if (Model.IsUndecided)
                    {
                        <text>· expires @app.ExpiresAtUtc.ToString("MMM d") if undecided</text>
                    }
                    else if (app.DecidedAtUtc is { } decided)
                    {
                        <text>· decided @ApplicationDisplay.RelativeTime(decided)</text>
                    }
                </p>
                @if (!Model.ViewerIsOrganizer && app.Organizer.RatingSummary is { } summary)
                {
                    <p class="request-trust">
                        <span aria-hidden="true">★</span> @BookingDisplay.RatingAverage(summary.AverageStars) (@summary.RatingCount)
                        · @summary.CompletedBookings completed
                        @if (summary.NoShowCount > 0)
                        {
                            <text> · @summary.NoShowCount no-show@(summary.NoShowCount == 1 ? "" : "s")</text>
                        }
                    </p>
                }
            </div>

            @* Host review (CONTRACTS §6): the manager-only conflict verdict + a CSS mini-week
               strip + competing pending demand, rendered inline from the detail payload the page
               already fetched (no extra lazy fetch). Organizers never see this block. *@
            @if (!Model.ViewerIsOrganizer && app.Conflicts is { } conflicts)
            {
                var miniWeek = HostReviewDisplay.BuildMiniWeek(app.Schedule, conflicts);
                <section class="host-review" aria-label="Availability check">
                    <partial name="~/Views/Apply/_ConflictSummary.cshtml" model="HostReviewDisplay.ToVerdict(conflicts)" />

                    <ol class="cal-mini" role="list" aria-label="Requested days this week">
                        @foreach (var cell in miniWeek)
                        {
                            <li class="cal-mini-cell @cell.CssClass">
                                <span class="cal-mini-dow" aria-hidden="true">@cell.DayInitial</span>
                                <span class="sr-only">@cell.DayLabel — @cell.StateLabel</span>
                            </li>
                        }
                    </ol>

                    @if (conflicts.PendingOverlaps.Count > 0)
                    {
                        <p class="host-overlap">
                            @conflicts.PendingOverlaps.Count other pending request@(conflicts.PendingOverlaps.Count == 1 ? "" : "s")
                            want overlapping times:
                            @for (var i = 0; i < conflicts.PendingOverlaps.Count; i++)
                            {
                                var overlap = conflicts.PendingOverlaps[i];
                                <a href="@Url.Content($"~/manage/applications/{overlap.ApplicationId}")">@overlap.OrganizerName</a>
                                <text> (@overlap.OverlappingDateCount date@(overlap.OverlappingDateCount == 1 ? "" : "s"))</text>@(i < conflicts.PendingOverlaps.Count - 1 ? ", " : ".")
                            }
                        </p>
                    }
                </section>
            }

            @if (app.Messages.Count > 0)
            {
                <ol class="thread-messages" role="list" aria-label="Messages">
                    @foreach (var message in app.Messages)
                    {
                        var mine = message.SenderId == Model.ViewerId;
                        <li class="thread-message @(mine ? "is-mine" : "")">
                            <p class="thread-message-body">@message.Body</p>
                            <p class="thread-message-meta">
                                @(mine ? "You" : Model.SenderName(message.SenderId)) · @ApplicationDisplay.RelativeTime(message.SentAtUtc)
                            </p>
                        </li>
                    }
                </ol>
            }

            @if (Model.AcceptsMessages)
            {
                <form method="post" action="@replyUrl" class="thread-reply">
                    @Html.AntiForgeryToken()
                    <label class="field-label" for="thread-reply-body">
                        @(Model.ViewerIsOrganizer ? $"Message {app.VenueName}" : $"Ask {app.Organizer.DisplayName} a question")
                    </label>
                    <textarea class="form-input" id="thread-reply-body" name="body" rows="3" maxlength="2000" required
                              placeholder="@(Model.ViewerIsOrganizer ? "Anything else they should know…" : "Anything you need to know before deciding…")"></textarea>
                    <div class="thread-reply-actions">
                        <button type="submit" class="btn @(Model.ViewerIsOrganizer ? "btn-primary" : "btn-ghost")">
                            @(Model.ViewerIsOrganizer ? "Send answer" : "Send question")
                        </button>
                    </div>
                </form>
            }
            else
            {
                <p class="thread-closed">This request is closed — the thread is kept for your records.</p>
            }
        </div>

        <aside class="thread-aside">
            @if (!Model.ViewerIsOrganizer && Model.ProviderCanDecline)
            {
                <div class="decision-card">
                    <p class="decision-heading">Your decision</p>
                    <p class="decision-note">
                        @app.Organizer.DisplayName gets notified either way. A question first is always fine.
                    </p>
                    @if (Model.IsCounterOffered)
                    {
                        <p class="decision-waiting" role="note">
                            Waiting on the organizer — you can still decline or suggest again.
                        </p>
                    }
                    <form method="post" action="@Url.Content($"~/manage/applications/{app.Id}/decision")" class="decision-form">
                        @Html.AntiForgeryToken()
                        <label class="field-label" for="decision-message">Add a note (optional)</label>
                        <textarea class="form-input" id="decision-message" name="message" rows="2" maxlength="2000"
                                  placeholder="E.g. the side door will be unlocked from 8:45."></textarea>
                        <div class="decision-actions">
                            @if (Model.ProviderCanApprove)
                            {
                                <button type="submit" class="btn btn-primary" name="decision" value="approve">Approve</button>
                            }
                            <button type="submit" class="btn btn-danger" name="decision" value="decline">Decline</button>
                        </div>
                    </form>
                    @if (Model.ProviderCanCounter)
                    {
                        <partial name="_CounterOffer" model="Model" />
                    }
                </div>
            }

            @if (Model.ViewerIsOrganizer && Model.IsUndecided)
            {
                <div class="withdraw-card">
                    <details class="account-confirm">
                        <summary>Withdraw this request</summary>
                        <p class="decision-note">@app.VenueName will simply see it disappear from their pending list.</p>
                        <form method="post" action="@Url.Content($"~/inbox/applications/{app.Id}/withdraw")">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger">Withdraw request</button>
                        </form>
                    </details>
                </div>
            }

            @if (app.Status == "approved" && Model.ViewerIsOrganizer)
            {
                <div class="approved-card">
                    <p class="approved-heading">You're in 🎉</p>
                    <p class="decision-note">
                        @app.VenueName approved your request. Arrangements from here (keys, access, set-up)
                        happen directly with the venue — use the thread above if anything's unclear.
                    </p>
                    @if (app.BookingId is { } bookingId)
                    {
                        <a class="btn btn-primary" href="@Url.Content($"~/bookings/{bookingId}")">View your booking</a>
                    }
                </div>
            }

            @if (app.Status == "approved" && !Model.ViewerIsOrganizer && app.BookingId is { } providerBookingId)
            {
                <div class="decision-card">
                    <p class="decision-heading">Booking confirmed</p>
                    <p class="decision-note">
                        The approved dates are held for @app.Organizer.DisplayName — overlapping requests
                        can no longer be approved.
                    </p>
                    <a class="btn btn-ghost" href="@Url.Content($"~/bookings/{providerBookingId}")">View the booking</a>
                </div>
            }
        </aside>
    </div>
</section>
