@{
    ViewData["Title"] = "Inbox unavailable";
    ViewData["Robots"] = "noindex,nofollow";
}

<section class="inbox-page wrap">
    <div class="empty-state">
        <p class="empty-emoji" aria-hidden="true">📮</p>
        <h1 class="empty-title">Can't open your inbox right now</h1>
        <p class="empty-body">Something's wrong on our side. Give it a minute and refresh — nothing has been lost.</p>
        <a class="btn btn-ghost" href="~/">Back to browsing</a>
    </div>
</section>
