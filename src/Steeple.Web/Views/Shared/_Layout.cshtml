@inject Steeple.Web.Services.IFeatureFlags Flags
@{
    var year = DateTime.UtcNow.Year;
    var manageEnabled = Flags.IsEnabled("web.manage_enabled");
    // The discovery/home page opts into the wide app shell so the header + footer line up with
    // its full-width map layout; reading pages keep the narrower centred shell.
    var shell = (ViewData["WideShell"] as bool?) == true ? "wrap-wide" : "wrap";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@(ViewData["Title"] is null ? $"{Brand.Name} — {Brand.Tagline}" : ViewData["Title"] + " · " + Brand.Name)</title>
    @{
        var metaDesc = ViewData["Description"] as string
            ?? "Churches opening their halls to the neighbourhood — find a friendly local space near you.";
        var pageTitle = ViewData["Title"] is string vt ? vt + " · " + Brand.Name : $"{Brand.Name} — {Brand.Tagline}";
        var canonical = ViewData["Canonical"] as string;
        var ogImage = ViewData["OgImage"] as string;
    }
    <meta name="description" content="@metaDesc" />
    @if (ViewData["Robots"] is string robotsDirective)
    {
        <meta name="robots" content="@robotsDirective" />
    }
    @if (canonical is not null)
    {
        <link rel="canonical" href="@canonical" />
    }

    <meta property="og:site_name" content="@Brand.Name" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="@pageTitle" />
    <meta property="og:description" content="@metaDesc" />
    @if (canonical is not null)
    {
        <meta property="og:url" content="@canonical" />
    }
    @if (ogImage is not null)
    {
        <meta property="og:image" content="@ogImage" />
    }
    <meta name="twitter:card" content="@(ogImage is not null ? "summary_large_image" : "summary")" />
    <meta name="twitter:title" content="@pageTitle" />
    <meta name="twitter:description" content="@metaDesc" />
    @if (ogImage is not null)
    {
        <meta name="twitter:image" content="@ogImage" />
    }

    @if (ViewData["PreconnectOrigins"] is IReadOnlyList<string> preconnectOrigins)
    {
        @* Warm the connection to the photo CDN origin(s) (max 2) so the first card/gallery image
           doesn't pay the DNS+TCP+TLS cost cold. dns-prefetch is the no-handshake fallback for
           browsers that don't support preconnect. *@
        foreach (var origin in preconnectOrigins)
        {
            <link rel="preconnect" href="@origin" />
            <link rel="dns-prefetch" href="@origin" />
        }
    }

    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
          integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header">
        <div class="@shell header-inner">
            <a class="wordmark" href="~/" aria-label="@(Brand.Name + " home")">
                <span class="wordmark-dot" aria-hidden="true"></span>
                <span class="wordmark-text">@Brand.Name</span>
            </a>
            <p class="tagline">@Brand.Tagline</p>
            <nav class="header-actions" aria-label="Account">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a class="btn btn-ghost btn-sm" href="~/inbox">Inbox</a>
                    <a class="btn btn-ghost btn-sm" href="~/bookings">Bookings</a>
                    @if (manageEnabled)
                    {
                        <a class="btn btn-ghost btn-sm" href="~/manage">Your spaces</a>
                    }
                    <a class="btn btn-ghost btn-sm" href="~/account">Account</a>
                }
                else
                {
                    <a class="btn btn-ghost btn-sm" href="~/login">Log in</a>
                }
                <a class="btn btn-primary btn-sm" href="~/host">Become a host</a>
            </nav>
        </div>
    </header>

    <main id="main" class="site-main">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="@shell footer-grid">
            <div class="footer-brand">
                <span class="wordmark wordmark-sm">
                    <span class="wordmark-dot" aria-hidden="true"></span>
                    <span class="wordmark-text">@Brand.Name</span>
                </span>
                <p class="footer-tagline">@Brand.FooterTagline</p>
            </div>

            <nav class="footer-links" aria-label="Footer">
                <a href="~/about">About</a>
                <a href="~/host">Become a host</a>
                <a href="~/privacy">Privacy</a>
                <a href="~/terms">Terms &amp; safety</a>
            </nav>

            <div class="footer-app">
                <p class="footer-app-eyebrow">Coming soon</p>
                <p class="footer-app-title">Get the @Brand.Name app</p>
                <p class="footer-app-note">Browse here; apply and message hosts on the go.</p>
                <div class="store-badges" role="list" aria-label="App stores — coming soon">
                    <span class="store-badge" role="listitem">App Store</span>
                    <span class="store-badge" role="listitem">Google Play</span>
                </div>
            </div>
        </div>
        <div class="@shell footer-bottom">
            <p class="footer-meta">© @year @Brand.Name@(ViewData["AreaName"] is string a && a.Length > 0 ? " · " + a : "")</p>
        </div>
    </footer>

    <script src="~/js/htmx.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script src="~/js/map.js" defer></script>
    <script src="~/js/site.js" defer></script>
    @await RenderSectionAsync("scripts", required: false)
</body>
</html>
