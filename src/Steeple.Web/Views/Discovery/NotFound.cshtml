@{
    ViewData["Title"] = "Space not found";
}

<section class="notfound wrap">
    <p class="notfound-emoji" aria-hidden="true">🚪</p>
    <h1 class="notfound-title">We couldn't find that space</h1>
    <p class="notfound-body">
        It may have been taken down, or the link might have a typo. Spaces come and go as halls
        open up around the neighbourhood.
    </p>
    <a class="btn btn-primary" href="~/">Browse community spaces</a>
</section>
