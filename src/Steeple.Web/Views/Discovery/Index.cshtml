@model DiscoveryViewModel
@{
    ViewData["Title"] = "Find a community space";
    ViewData["AreaName"] = Model.AreaName;
    ViewData["WideShell"] = true;

    var hasFilters = Model.Query.FreeOnly
        || Model.Query.MinCapacity.HasValue
        || !string.IsNullOrWhiteSpace(Model.Query.Suburb)
        || Model.Query.Activities != ActivityType.None
        || Model.Query.Accessibility != AccessibilityFeature.None
        || Model.Query.HasWhenFilter;

    var today = DateTime.Today.ToString("yyyy-MM-dd");
    var isWeekly = Model.Query.IsWeekly;
    var timeBands = new[]
    {
        new FilterOption("morning", "Morning"),
        new FilterOption("afternoon", "Afternoon"),
        new FilterOption("evening", "Evening"),
    };
}

<section class="hero wrap-wide" aria-labelledby="hero-heading">
    <div class="hero-text">
        <h1 id="hero-heading" class="hero-heading">Find a friendly hall near you</h1>
        <p class="hero-sub">
            Local churches and community spaces, opened up for the neighbourhood — children's groups,
            rehearsals, classes, gatherings. Many are free to use.
        </p>
    </div>
</section>

<div class="discovery">
    <div class="filter-sentinel" aria-hidden="true"></div>
    <form id="filter-form"
          class="filter-bar"
          hx-get="@Url.Content("~/search")"
          hx-target="#results"
          hx-push-url="true"
          hx-trigger="change, submit, keyup changed delay:400ms from:input[name=MinCapacity], keyup changed delay:500ms from:input[name=Suburb]"
          role="search"
          aria-label="Filter community spaces">

        <div class="filter-primary">
            <div class="search-field">
                <span class="search-ico" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 10c0 6-9 12-9 12s-9-6-9-12a9 9 0 0 1 18 0Z" />
                        <circle cx="12" cy="10" r="3" />
                    </svg>
                </span>
                <input class="search-input" type="text" name="Suburb"
                       list="suburb-list" value="@Model.Query.Suburb"
                       placeholder="Search a suburb…" autocomplete="off"
                       aria-label="Search by suburb" />
                <datalist id="suburb-list">
                    @foreach (var s in Model.SuburbOptions)
                    {
                        <option value="@s"></option>
                    }
                </datalist>
            </div>

            <label class="field field-capacity">
                <span class="field-label">Min capacity</span>
                <input class="field-input" type="number" name="MinCapacity" min="1" step="1"
                       inputmode="numeric" placeholder="Any"
                       value="@(Model.Query.MinCapacity?.ToString() ?? "")" />
            </label>

            @* JS-only summarizing trigger for the When popover (site.js unhides it and collapses
               the .filter-when row into the anchored panel). No JS: stays hidden, inline row remains. *@
            <button type="button" class="when-trigger" data-when-trigger hidden
                    aria-haspopup="dialog" aria-expanded="false">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="3" y="4" width="18" height="18" rx="2" />
                    <line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" />
                    <line x1="3" y1="10" x2="21" y2="10" />
                </svg>
                <span class="when-trigger-label">When:</span>
                <span class="when-trigger-summary" data-when-summary>Any time</span>
                <span class="when-trigger-caret" aria-hidden="true">▾</span>
            </button>

            <label class="toggle toggle-pill">
                <input type="checkbox" name="FreeOnly" value="true" @(Model.Query.FreeOnly ? "checked" : "") />
                <span class="toggle-label">Free only</span>
            </label>

            @if (hasFilters)
            {
                <a class="filter-clear" href="~/">Clear all</a>
            }
        </div>

        @* When (time-first search, §8.12 / CONTRACTS §3). Plain form fields inside the HTMX form
           so the selection rides the swap + hx-push-url; site.js handles the reveals and the
           date⇄weekday / band⇄custom mutual exclusion. No JS: everything visible, still submittable. *@
        <div class="filter-when" data-when-control>
            <div class="when-panel" data-when-panel>
            <div class="when-mode chip-set" data-when-mode hidden role="group" aria-label="How often">
                <button type="button" class="chip-btn is-selected" data-when-mode-btn="once">Just once</button>
                <button type="button" class="chip-btn" data-when-mode-btn="weekly">Weekly</button>
            </div>

            @* JS-rendered plain date picker (no availability semantics — that lives on the apply
               calendar, §8.10). Writes into the real date input below. *@
            <div class="when-cal" data-when-calendar hidden></div>

            <div class="when-row">
                <fieldset class="filter-group when-band">
                    <legend class="filter-legend">Time of day</legend>
                    <div class="chip-set">
                        @foreach (var band in timeBands)
                        {
                            <label class="chip">
                                <input type="radio" name="timeOfDay" value="@band.Value"
                                       data-when-band
                                       @(string.Equals(Model.Query.TimeOfDay, band.Value, StringComparison.OrdinalIgnoreCase) ? "checked" : "") />
                                <span class="chip-text">@band.Label</span>
                            </label>
                        }
                        <button type="button" class="when-custom-btn" data-when-custom-toggle
                                aria-expanded="@(Model.Query.HasCustomTime ? "true" : "false")">Custom time</button>
                    </div>
                </fieldset>

                <label class="field when-date" data-when-date>
                    <span class="field-label">On date</span>
                    <input class="field-input when-date-input" type="date" name="date" min="@today"
                           value="@(Model.Query.Date?.ToString("yyyy-MM-dd") ?? "")" />
                </label>

                <label class="toggle when-weekly-toggle">
                    <input type="checkbox" data-when-weekly @(isWeekly ? "checked" : "") />
                    <span class="toggle-label">Weekly on…</span>
                </label>
            </div>

            <div class="when-custom" data-when-custom hidden="@(!Model.Query.HasCustomTime)">
                <label class="field">
                    <span class="field-label">From</span>
                    <input class="field-input" type="time" name="startTime" value="@(Model.Query.StartTime ?? "")" />
                </label>
                <label class="field">
                    <span class="field-label">To</span>
                    <input class="field-input" type="time" name="endTime" value="@(Model.Query.EndTime ?? "")" />
                </label>
            </div>

            <fieldset class="filter-group when-weekdays" data-when-weekdays hidden="@(!isWeekly)">
                <legend class="filter-legend">Weekly on</legend>
                <div class="chip-set">
                    @foreach (var day in ApplyViewModel.DayOptions)
                    {
                        <label class="chip">
                            <input type="checkbox" name="daysOfWeek" value="@day.Value"
                                   @(Model.Query.IsWeekdaySelected(day.Value) ? "checked" : "") />
                            <span class="chip-text">@day.Label</span>
                        </label>
                    }
                </div>
            </fieldset>

            <div class="when-panel-foot" data-when-foot hidden>
                <button type="button" class="when-clear-btn" data-when-clear>Clear</button>
                <button type="button" class="btn btn-primary btn-sm" data-when-done>Done</button>
            </div>
            </div>
        </div>

        <div class="filter-facets">
            <fieldset class="filter-group">
                <legend class="filter-legend">Activity</legend>
                <div class="chip-set">
                    @foreach (var opt in Model.ActivityOptions)
                    {
                        <label class="chip">
                            <input type="checkbox" name="Activities" value="@opt.Value"
                                   @(Model.IsActivitySelected(opt.Value) ? "checked" : "") />
                            <span class="chip-text">@opt.Label</span>
                        </label>
                    }
                </div>
            </fieldset>

            <fieldset class="filter-group">
                <legend class="filter-legend">Accessibility</legend>
                <div class="chip-set">
                    @foreach (var opt in Model.AccessibilityOptions)
                    {
                        <label class="chip">
                            <input type="checkbox" name="Accessibility" value="@opt.Value"
                                   @(Model.IsAccessibilitySelected(opt.Value) ? "checked" : "") />
                            <span class="chip-text">@opt.Label</span>
                        </label>
                    }
                </div>
            </fieldset>
        </div>

        <noscript>
            <button class="btn btn-primary" type="submit">Search</button>
        </noscript>
    </form>

    <div class="map-toggle" role="group" aria-label="Show list or map">
        <button type="button" class="map-toggle-btn is-active" data-view="list" aria-pressed="true">List</button>
        <button type="button" class="map-toggle-btn" data-view="map" aria-pressed="false">Map</button>
    </div>

    @* Persistent, screen-reader-only status: site.js updates it with just the new count after
       each HTMX swap, so the results list itself need not be a live region (which would re-read
       every card on every filter change). *@
    <p id="results-status" class="sr-only" role="status" aria-live="polite"></p>

    <div class="discovery-grid">
        <div id="results" class="results-col" data-view-pane="list">
            @await Html.PartialAsync("_Results", Model)
        </div>

        <div class="map-col" data-view-pane="map">
            <div id="map" class="map" aria-label="Map of community spaces">
                <p class="map-fallback">Map unavailable — browse the list of spaces instead.</p>
            </div>
        </div>
    </div>
</div>
