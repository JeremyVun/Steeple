@model VenueEditorViewModel
@{
    var venue = Model.Venue;
    var (verificationRole, verificationLabel) = VerificationStatusChip(venue);
}

<section class="inbox-page wrap">
    <header class="inbox-head">
        <h1>@venue.Name</h1>
        <partial name="_ManageTabs" model="@("spaces")" />
    </header>

    <p class="manage-breadcrumb"><a href="~/manage">← Your spaces</a></p>

    @if (Model.Flash is not null)
    {
        <p class="thread-flash" role="status">@Model.Flash</p>
    }

    <div class="manage-editor-grid">
        <section class="card manage-card" aria-labelledby="venue-rooms-heading">
            <div class="card-body">
                <h2 id="venue-rooms-heading">Rooms</h2>
                @if (venue.Rooms.Count == 0)
                {
                    <div class="empty-state">
                        <p>No rooms yet — the room is what organizers actually find and book.</p>
                        <a class="btn btn-primary" href="~/manage/venues/@venue.Id/rooms/new">Add your first room</a>
                    </div>
                }
                else
                {
                    <ul class="manage-room-list" role="list">
                        @foreach (var room in venue.Rooms)
                        {
                            <li class="manage-room-row">
                                <a class="manage-room-link" href="~/manage/rooms/@room.Id">
                                    @if (room.PrimaryPhotoUrl is not null)
                                    {
                                        <img class="manage-room-thumb" src="@room.PrimaryPhotoUrl" alt="" loading="lazy" />
                                    }
                                    else
                                    {
                                        <span class="manage-room-thumb manage-room-thumb-empty" aria-hidden="true">@(room.Name.Length > 0 ? room.Name[..1] : "•")</span>
                                    }
                                    <span class="manage-room-name">
                                        <strong>@room.Name</strong>
                                        <span class="card-meta">Up to @room.Capacity · @(room.IsFree ? "Free" : $"${room.PricePerHour:0.##}/hr") · @room.PhotoCount photo@(room.PhotoCount == 1 ? "" : "s")</span>
                                    </span>
                                    @{ var (role, label) = RoomStatusChip(room); }
                                    <span class="status-chip status-@role">@label</span>
                                </a>
                            </li>
                        }
                    </ul>
                    <p class="manage-add-row"><a class="btn btn-ghost" href="~/manage/venues/@venue.Id/rooms/new">Add another room</a></p>
                }
            </div>
        </section>

        <div class="manage-editor-side">
            <section class="card manage-card" aria-labelledby="venue-details-heading">
                <div class="card-body">
                    <h2 id="venue-details-heading">Venue details</h2>
                    <form method="post" action="@Url.Content($"~/manage/venues/{venue.Id}")" class="manage-form">
                        @Html.AntiForgeryToken()
                        <partial name="_VenueFields" model="Model.Form" />
                        <div class="form-field manage-form-actions">
                            <button class="btn btn-primary" type="submit">Save venue details</button>
                        </div>
                    </form>
                </div>
            </section>
    
            <section class="card manage-card" aria-labelledby="venue-verification-heading">
                <div class="card-body">
                    <div class="manage-status-line">
                        <h2 id="venue-verification-heading">Venue verification</h2>
                        <span class="status-chip status-@verificationRole">@verificationLabel</span>
                    </div>
    
                    @if (venue.VerificationStatus == "verified")
                    {
                        <p class="field-help">This venue is verified for ownership or lease authority.</p>
                    }
                    else if (venue.VerificationStatus == "pending")
                    {
                        <p class="field-help">Submitted @venue.VerificationRequestedAtUtc?.ToString("MMM d, yyyy"). We review verification before a venue's first listing goes live.</p>
                    }
                    else
                    {
                        @if (Model.VerificationForm.Error is not null)
                        {
                            <p class="auth-error" role="alert">@Model.VerificationForm.Error</p>
                        }
                        <form method="post" action="@Url.Content($"~/manage/venues/{venue.Id}/verification")" class="manage-form">
                            @Html.AntiForgeryToken()
                            <div class="form-row">
                                <label class="form-field">
                                    <span>Contact name</span>
                                    <input class="form-input" name="ContactName" value="@Model.VerificationForm.ContactName" maxlength="200" required />
                                </label>
                                <label class="form-field">
                                    <span>Contact email <span class="field-optional">(optional)</span></span>
                                    <input class="form-input" type="email" name="ContactEmail" value="@Model.VerificationForm.ContactEmail" maxlength="320" />
                                </label>
                            </div>
                            <label class="form-field">
                                <span>Ownership or lease authority</span>
                                <textarea class="form-input" name="EvidenceSummary" rows="4" maxlength="4000" required>@Model.VerificationForm.EvidenceSummary</textarea>
                            </label>
                            <fieldset class="form-fieldset">
                                <legend>Document links</legend>
                                <div class="form-row">
                                    <label class="form-field">
                                        <span>Document 1 label</span>
                                        <input class="form-input" name="Document1Label" value="@Model.VerificationForm.Document1Label" maxlength="200" required />
                                    </label>
                                    <label class="form-field">
                                        <span>Document 1 URL</span>
                                        <input class="form-input" type="url" name="Document1Url" value="@Model.VerificationForm.Document1Url" maxlength="1000" required />
                                    </label>
                                </div>
                                <div class="form-row">
                                    <label class="form-field">
                                        <span>Document 2 label <span class="field-optional">(optional)</span></span>
                                        <input class="form-input" name="Document2Label" value="@Model.VerificationForm.Document2Label" maxlength="200" />
                                    </label>
                                    <label class="form-field">
                                        <span>Document 2 URL <span class="field-optional">(optional)</span></span>
                                        <input class="form-input" type="url" name="Document2Url" value="@Model.VerificationForm.Document2Url" maxlength="1000" />
                                    </label>
                                </div>
                                <div class="form-row">
                                    <label class="form-field">
                                        <span>Document 3 label <span class="field-optional">(optional)</span></span>
                                        <input class="form-input" name="Document3Label" value="@Model.VerificationForm.Document3Label" maxlength="200" />
                                    </label>
                                    <label class="form-field">
                                        <span>Document 3 URL <span class="field-optional">(optional)</span></span>
                                        <input class="form-input" type="url" name="Document3Url" value="@Model.VerificationForm.Document3Url" maxlength="1000" />
                                    </label>
                                </div>
                            </fieldset>
                            <label class="form-field manage-check">
                                <span>
                                    <input type="checkbox" name="AttestedAuthority" value="true" @(Model.VerificationForm.AttestedAuthority ? "checked" : "") required />
                                    I confirm I am authorized to list or lease rooms for this venue.
                                </span>
                            </label>
                            <input type="hidden" name="AttestedAuthority" value="false" />
                            <div class="form-field manage-form-actions">
                                <button class="btn btn-primary" type="submit">Submit for verification</button>
                            </div>
                        </form>
                    }
                </div>
            </section>
        </div>
    </div>
</section>

@functions {
    // Manage-only status tokens (CONTRACTS §2.1) — public surfaces never see these.
    private static (string Role, string Label) RoomStatusChip(ManagedRoomSummaryDto room) => room switch
    {
        { PublishRequestedAtUtc: not null } => ("warning", "In review"),
        { Status: "published" } => ("success", "Published"),
        { Status: "unlisted" } => ("neutral", "Unlisted"),
        _ => ("neutral", "Draft"),
    };

    private static (string Role, string Label) VerificationStatusChip(ManagedVenueDetailDto venue) =>
        venue.VerificationStatus switch
        {
            "verified" => ("success", "Verified"),
            "pending" => ("warning", "Verification in review"),
            "declined" => ("danger", "Verification declined"),
            _ => ("neutral", "Unverified"),
        };
}
