@{
    var returnUrl = ViewData["ReturnUrl"] as string ?? Url.Content("~/");
    var signInEnabled = (ViewData["SignInEnabled"] as bool?) == true;
    var googleClientId = ViewData["GoogleClientId"] as string ?? "";
    var appleEnabled = (ViewData["AppleEnabled"] as bool?) == true;
    var turnstileSiteKey = ViewData["TurnstileSiteKey"] as string ?? "";
    var googleEnabled = googleClientId.Length > 0;
    var devEnabled = (ViewData["DevLoginEnabled"] as bool?) == true;
    var authError = TempData["AuthError"] as string;
}

<section class="auth-page wrap" aria-labelledby="auth-heading">
    <div class="auth-card">
        <p class="content-eyebrow">@Brand.Name</p>
        <h1 id="auth-heading">Log in or sign up</h1>
        <p class="auth-sub">One account to apply for spaces, message hosts, and manage your own listings.</p>

        @if (authError is not null)
        {
            <p class="auth-error" role="alert">@authError</p>
        }

        @if (!signInEnabled)
        {
            <div class="auth-providers">
                <button type="button" class="auth-btn" disabled aria-disabled="true">Continue with Google</button>
                <button type="button" class="auth-btn" disabled aria-disabled="true">Continue with Apple</button>
            </div>

            <p class="auth-note">
                Accounts are coming soon. While @Brand.Name is in preview you can browse every space and contact
                venues directly — no sign-in needed.
            </p>
        }
        else if (!googleEnabled && !appleEnabled && !devEnabled)
        {
            <p class="auth-note">Sign-in isn't available right now. Please try again later.</p>
        }
        else
        {
            @* Sign-in config for js/auth.js (CSP forbids inline scripts). When Turnstile is
               configured the providers stay hidden until the widget hands us a token. *@
            <div id="auth-config"
                 data-google-client-id="@googleClientId"
                 data-turnstile-enabled="@(turnstileSiteKey.Length > 0 ? "true" : "false")"></div>

            @if (turnstileSiteKey.Length > 0)
            {
                <div class="cf-turnstile"
                     data-sitekey="@turnstileSiteKey"
                     data-callback="steepleTurnstileDone"
                     data-appearance="interaction-only"></div>
                <p class="auth-note" id="auth-waiting">Checking your browser…</p>
            }

            <div class="auth-providers @(turnstileSiteKey.Length > 0 ? "auth-hidden" : "")" id="auth-providers">
                @if (googleEnabled)
                {
                    @* Google Identity Services renders its own button here (brand-guideline
                       compliant — DESIGN_SYSTEM §8.1 exempts SSO buttons from the palette). Its JS
                       callback drops the credential into the form below and submits it, keeping
                       the POST same-origin so the antiforgery token applies. *@
                    <div id="google-signin"></div>

                    <form id="google-form" method="post" action="~/auth/google/callback" hidden>
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="credential" id="google-credential" value="" />
                        <input type="hidden" name="turnstileToken" class="turnstile-token" value="" />
                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                    </form>
                }

                @if (appleEnabled)
                {
                    <form method="post" action="~/auth/apple/start">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="turnstileToken" class="turnstile-token" value="" />
                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                        <button type="submit" class="auth-btn auth-btn-apple">
                            <svg viewBox="0 0 17 20" width="15" height="18" aria-hidden="true" focusable="false">
                                <path fill="currentColor" d="M14.2 10.6c0-2.3 1.9-3.4 2-3.5-1.1-1.6-2.8-1.8-3.4-1.8-1.4-.1-2.8.8-3.5.8-.7 0-1.9-.8-3.1-.8C4.6 5.3 3 6.2 2.1 7.7c-1.8 3.1-.5 7.7 1.3 10.2.9 1.2 1.9 2.6 3.2 2.6 1.3-.1 1.8-.8 3.3-.8s2 .8 3.3.8c1.4 0 2.3-1.2 3.1-2.5 1-1.4 1.4-2.8 1.4-2.9-.1 0-2.7-1-2.7-4.1l1.2-.4zM11.9 3.1c.7-.8 1.1-2 1-3.1-1 0-2.2.7-2.9 1.5-.6.7-1.2 1.9-1 3 1.1.1 2.2-.6 2.9-1.4z"/>
                            </svg>
                            Continue with Apple
                        </button>
                    </form>
                }
            </div>

            @if (devEnabled)
            {
                @* Development-only sign-in (Auth:DevLoginEnabled — never set outside
                   appsettings.Development.json). Stands in for SSO in the dev loop and
                   automated playtests. *@
                <form class="auth-dev" method="post" action="~/auth/dev/callback">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <p class="field-label">Dev sign-in <span class="field-optional">Development only</span></p>
                    <div class="form-field">
                        <label class="field-label" for="dev-email">Email</label>
                        <input class="form-input" id="dev-email" name="email" type="email" required
                               placeholder="maria@example.com" />
                    </div>
                    <div class="form-field">
                        <label class="field-label" for="dev-name">Name <span class="field-optional">optional</span></label>
                        <input class="form-input" id="dev-name" name="displayName" maxlength="200"
                               placeholder="Maria Lopez" />
                    </div>
                    <button type="submit" class="auth-btn">Continue as this person</button>
                </form>
            }

            <p class="auth-consent">
                By continuing you agree to the
                <a href="~/terms">terms of use</a> (v@(Steeple.Web.Configuration.LegalDocuments.TosVersion)) and
                <a href="~/privacy">privacy policy</a> (v@(Steeple.Web.Configuration.LegalDocuments.PrivacyVersion)).
            </p>
        }

        <a class="auth-back" href="@returnUrl">← Back to browsing</a>
    </div>
</section>

@section scripts {
    @if (signInEnabled && (googleEnabled || appleEnabled))
    {
        <script src="~/js/auth.js" asp-append-version="true"></script>
        @if (googleEnabled)
        {
            <script src="https://accounts.google.com/gsi/client" async defer></script>
        }
        @if (turnstileSiteKey.Length > 0)
        {
            <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
        }
    }
}
