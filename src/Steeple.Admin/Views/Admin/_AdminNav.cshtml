@model Steeple.Admin.ViewModels.Admin.AdminWorkspaceViewModel
@{
    var active = ViewData["ActiveSection"] as string ?? "overview";
    var items = new (string Key, string Label, string Href)[]
    {
        ("overview", "Overview", "~/admin"),
        ("users", "Users", "~/admin/users"),
        ("listings", "Listings", "~/admin/listings"),
        ("applications", "Applications", "~/admin/applications"),
        ("moderation", "Moderation", "~/admin/moderation"),
        ("analytics", "Analytics", "~/admin/analytics"),
        ("flags", "Flags", "~/admin/feature-flags"),
        ("account", "Account", "~/admin/account"),
    };
}

<header class="admin-topbar">
    <div class="admin-topbar-head">
        <p class="admin-eyebrow">Steeple operations</p>
        <h1>Admin dashboard</h1>
    </div>
    <nav class="admin-nav" aria-label="Admin sections">
        @foreach (var item in items)
        {
            var isActive = item.Key == active;
            <a href="@Url.Content(item.Href)"
               class="admin-nav-link@(isActive ? " is-active" : "")"
               aria-current="@(isActive ? "page" : null)">@item.Label</a>
        }
    </nav>
</header>
