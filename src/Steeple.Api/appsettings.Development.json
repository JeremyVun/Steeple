{
  "Logging": {
    "LogLevel": {
      "Steeple": "Debug"
    }
  },
  "ConnectionStrings": {
    "SteepleDb": "Host=localhost;Port=5433;Database=steeple;Username=steeple;Password=steeple_dev_pw"
  },
  "Auth": {
    // Dev-only signing key (safe to commit — never used outside the local loop).
    "Jwt": { "SigningKey": "TtDVdGEAWZGFYmJ9sMbac9NL5QuqNBJyXYGlzUiwClw=" },
    // Registers the "dev" identity provider (email-as-token sign-in) for the local loop and
    // automated playtests. Development-only by construction: base appsettings omits it.
    "DevLoginEnabled": true
  },
  // Client flags proxy (CONTRACTS §8) dev defaults: apply and manage are on locally, and no
  // build is ever force-upgraded.
  "Flags": {
    "mobile.apply_enabled": true,
    "mobile.manage_enabled": true,
    // On locally so the dev loop exercises the publish gate — the 009 seed backfill already gives
    // every Published room open hours, so nothing that ships published is blocked.
    "manage.open_hours_required": true,
    // On locally so the dev loop exercises guest availability reads + the submit-time hard block.
    "listing.availability": true,
    // On locally so the dev loop exercises host counter-offers (CONTRACTS §5).
    "booking.counter_offers": true,
    "MobileMinSupportedBuild": 0
  },
  // Local-disk media mode: uploads land under media-store/ and the API serves them at /media —
  // the browser needs an absolute origin it can reach.
  "Media": { "PublicBaseUrl": "http://localhost:5200" }
}
