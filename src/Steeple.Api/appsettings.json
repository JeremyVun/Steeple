{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  // Identity (CONTRACTS §4). Jwt:SigningKey is supplied per-environment (dev json / env var) so
  // no signing material ships in source-of-truth config; without it the API fails to start.
  // Provider ClientIds are the accepted `aud` values (web client id + mobile ids as they land);
  // empty lists reject that provider's tokens — fail closed until configured.
  "Auth": {
    "Jwt": {
      "Issuer": "steeple-api",
      "Audience": "steeple",
      "AccessTokenMinutes": 15
    },
    "RefreshTokenDays": 90,
    "Google": { "ClientIds": [] },
    "Apple": { "ClientIds": [] }
  },
  // Turnstile secret is deployment-supplied (Turnstile__SecretKey); empty = check disabled.
  "Turnstile": { "SecretKey": "" },
  // Transactional email (Resend adapter behind IEmailGateway). No ApiKey = log-only mode: the
  // notification inbox row is still written, the send is logged instead of delivered. Deployment
  // supplies Email__ApiKey / Email__From / Email__WebBaseUrl (absolute links in email bodies).
  "Email": {
    "ApiKey": "",
    "From": "Steeple <onboarding@resend.dev>",
    "WebBaseUrl": ""
  },
  // FCM push (behind IPushGateway). Neither set = LoggingPushGateway (log-only, no external
  // sends) — deployment supplies one via Push__ServiceAccountJson (preferred, a secret env var)
  // or Push__ServiceAccountJsonPath (a mounted key file).
  "Push": {
    "ServiceAccountJsonPath": "",
    "ServiceAccountJson": ""
  },
  // Client flags proxy (CONTRACTS §8): explicit public allowlist only (mobile.apply_enabled,
  // mobile.manage_enabled, mobile.force_upgrade) — fail closed like Web's Flags section. 0 =
  // MobileMinSupportedBuild never forces an upgrade.
  "Flags": {
    "mobile.apply_enabled": false,
    "mobile.manage_enabled": false,
    // Server-side gate (not a public client flag): require open hours before a room can publish.
    "manage.open_hours_required": false,
    // Server-side gate: guest availability reads + the submit-time schedule hard block (CONTRACTS §6).
    "listing.availability": false,
    "MobileMinSupportedBuild": 0
  },
  // Connection string is supplied per-environment: appsettings.Development.json for the local
  // `dotnet run` loop, ConnectionStrings__SteepleDb env var in Docker. Kept out of the base
  // (image-baked) file so no credential ships in source/the image and Production fails closed.
  // Geocoding (Manage module, provider address entry only — a metered SKU that must never sit
  // on a public hot path). No key = the dev stub resolves every address to the beachhead center.
  "Geocoding": { "GoogleApiKey": "", "Region": "VA" },
  // Media storage (SYSTEM_DESIGN §9). Spaces settings (deployment-supplied) select the S3/CDN
  // store; all empty = local-disk mode, served by the API itself at /media (dev loop).
  "Media": {
    "ServiceUrl": "",
    "Bucket": "",
    "AccessKey": "",
    "SecretKey": "",
    "PublicBaseUrl": "",
    "LocalRoot": "media-store"
  },
  "Geofence": {
    "AreaName": "Vienna & nearby (Northern Virginia)",
    "MinLatitude": 38.84,
    "MaxLatitude": 38.96,
    "MinLongitude": -77.34,
    "MaxLongitude": -77.12,
    "CenterLatitude": 38.9012,
    "CenterLongitude": -77.2653
  }
}
